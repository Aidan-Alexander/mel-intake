# MEL intake — secrets and config.
#
# Copy this file to ~/.mel-intake/.env and fill in the three secrets.
# The runtime dir (~/.mel-intake) lives OUTSIDE Google Drive on purpose, so your
# API keys are not synced to the cloud. Never commit a real .env.
#
#   mkdir -p ~/.mel-intake
#   cp ".env.example" ~/.mel-intake/.env
#   open -a TextEdit ~/.mel-intake/.env   # or edit however you like
#
# ---- REQUIRED SECRETS ----

# Airtable personal access token. Needs scopes: data.records:read + data.records:write,
# with this base added under the token's access (Builder/Editor role on the base).
# Create at https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Anthropic API key (used to summarise each thread with Claude Sonnet 4.6).
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Slack user OAuth token from the "Mel intake" Slack app (api.slack.com/apps).
# Long-lived (token rotation off). Scopes: channels:history, groups:history,
# channels:read, groups:read, users:read, chat:write, files:read.
SLACK_USER_TOKEN=xoxp-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ---- AIRTABLE TARGET (defaults already point at your base; override only if it moves) ----
AIRTABLE_BASE_ID=app6tmBJhcfCS7FLs
AIRTABLE_TABLE_ID=tblbtQqlp4z9uky47
AIRTABLE_CHARITIES_TABLE_ID=tblSsWP0lp1fH9kk6

# ---- SLACK / BEHAVIOUR (sensible defaults; override only if needed) ----
SLACK_WORKSPACE=ceincubationprogram
MEL_INTAKE_CHANNEL=C0B9WG6UY4W
ANTHROPIC_MODEL=claude-sonnet-4-6
MEL_CAPTURED_BY=MEL intake script
MEL_FIRST_RUN_LOOKBACK_DAYS=30
SLACK_HISTORY_LIMIT=200
MEL_LINK_CHARITIES=true

# PDF attachment reading: extract text from attached PDFs into the summary.
MEL_READ_PDFS=true
MEL_PDF_TEXT_MAXCHARS=12000
MEL_PDF_MAX_MB=25
MEL_MAX_PDFS=5

# Where to DM you if Slack auth fails before a session has been authed.
# Normally discovered automatically and cached in state.json; this is a fallback.
SLACK_ALERT_USER_ID=U03Q5UR8GQ7
